{
  "manifest_version": 3,
  "name": "True Resonance - 432Hz audio retuner",
  "version": "2.4.0",
  "minimum_chrome_version": "116",
  "description": "Retune Spotify, YouTube, Apple Music & any web audio to 432Hz, 528Hz & Solfeggio healing frequencies - in real time.",
  "author": "RafaCMur",
  "permissions": [
    "storage",
    "tabCapture",
    "offscreen",
    "tabs",
    "activeTab",
    "sidePanel"
  ],

  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "js": ["injected.js"],
      "world": "MAIN",
      "all_frames": true,
      "match_origin_as_fallback": true
    },
    {
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "js": ["content_script.js"],
      "all_frames": true,
      "match_origin_as_fallback": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["soundtouch-worklet.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
